# =============================================================================
# ElektraLog — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# NEVER commit .env to version control!
# =============================================================================

# ----------------------------------------------------------------------------
# App (Flutter Web)
# ----------------------------------------------------------------------------
APP_PORT=80
APP_DOMAIN=localhost

# ----------------------------------------------------------------------------
# PostgreSQL
# ----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=elektralog
POSTGRES_PASSWORD=changeme
POSTGRES_DB=elektralog
WIKIJS_DB=wikijs

# ----------------------------------------------------------------------------
# Serverpod
# ----------------------------------------------------------------------------
SERVERPOD_PORT=8080
SERVERPOD_INSIGHTS_PORT=8081

# ----------------------------------------------------------------------------
# JWT
# ----------------------------------------------------------------------------
JWT_SECRET=changeme_jwt_secret_min32chars

# ----------------------------------------------------------------------------
# Homepage
# ----------------------------------------------------------------------------
HOMEPAGE_PORT=8090

# ----------------------------------------------------------------------------
# Wiki.js
# ----------------------------------------------------------------------------
WIKI_PORT=3000
WIKI_SECRET=changeme_wikisecret

# ----------------------------------------------------------------------------
# Reverse Proxy (Traefik)
# ----------------------------------------------------------------------------
PROXY_HTTP_PORT=80
PROXY_HTTPS_PORT=443
ACME_EMAIL=admin@example.com
