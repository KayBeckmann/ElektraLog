# =============================================================================
# ElektraLog — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# NEVER commit .env to version control!
#
# Port-Hinweis: Der externe Reverse-Proxy (nginx, Caddy o.ä.) auf dem
# Hostserver übernimmt SSL-Terminierung und Routing. Hier nur die
# Host-Ports eintragen, auf die der Proxy weiterleitet.
# =============================================================================

# ----------------------------------------------------------------------------
# Flutter Web App
# ----------------------------------------------------------------------------
APP_PORT=8888

# ----------------------------------------------------------------------------
# Dart HTTP Backend (API)
# ----------------------------------------------------------------------------
SERVERPOD_PORT=8080

# ----------------------------------------------------------------------------
# PostgreSQL (nur lokal erreichbar — kein externer Zugriff nötig)
# ----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=elektralog
POSTGRES_PASSWORD=changeme
POSTGRES_DB=elektralog
WIKIJS_DB=wikijs

# ----------------------------------------------------------------------------
# JWT (min. 32 Zeichen, zufällig generieren: openssl rand -hex 32)
# ----------------------------------------------------------------------------
JWT_SECRET=changeme_jwt_secret_min32chars

# ----------------------------------------------------------------------------
# Projekt-Homepage (company-Profil)
# ----------------------------------------------------------------------------
HOMEPAGE_PORT=8090

# ----------------------------------------------------------------------------
# Wiki.js (company-Profil)
# ----------------------------------------------------------------------------
WIKI_PORT=3000
WIKI_SECRET=changeme_wikisecret
